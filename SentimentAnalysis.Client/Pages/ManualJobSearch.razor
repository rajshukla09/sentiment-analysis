@inject NavigationManager Navigation

<section class="card compact">
    <h2>Find an existing job</h2>
    <EditForm Model="@searchForm" OnSubmit="Go">
        <div class="search-row">
            <input @bind="searchForm.JobId" @bind:event="oninput" placeholder="Paste job ID" />
            <button type="submit">View Job</button>
        </div>
    </EditForm>
    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert error">@error</div>
    }
</section>

@code {
    private readonly SearchForm searchForm = new();
    private string? error;

    private void Go()
    {
        if (!Guid.TryParse(searchForm.JobId, out var id))
        {
            error = "Enter a valid GUID job ID.";
            return;
        }

        error = null;
        Navigation.NavigateTo($"jobs/{id}");
    }

    private sealed class SearchForm
    {
        public string? JobId { get; set; }
    }
}
